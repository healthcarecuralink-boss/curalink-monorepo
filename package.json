{
  "name": "curalink-monorepo",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "turbo run dev",
    "dev:curalink": "turbo run dev --filter=curalink",
    "dev:curalink-plus": "turbo run dev --filter=curalink-plus",
    "dev:curalink-team": "turbo run dev --filter=curalink-team",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "build:web": "turbo run build:web",
    "build:web:curalink": "turbo run build:web --filter=curalink",
    "build:web:curalink-plus": "turbo run build:web --filter=curalink-plus"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "eslint": "^9.39.5",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.9.5",
    "turbo": "^2.10.4",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.63.0"
  },
  "version": "1.0.0",
  "dependencies": {
    "expo": "~57.0.4",
    "react": "19.2.3",
    "react-native": "0.86.0"
  }
}
